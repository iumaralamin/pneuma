#!/bin/bash
 
# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Install openssh-server
sudo apt install openssh-server -y 

# Enable and start SSH server
echo "[2/8] Enabling SSH server..."
sudo systemctl enable ssh
sudo systemctl start ssh
 

# Create persistent tunnel script in /
 
sudo cat > /persistent-tunnel.sh << 'EOF'
#!/bin/bash
#!/bin/bash

# Colors
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

REMOTE_HOST="3.239.33.94"
KEY_FILE="/k.pem"
REMOTE_USER="ubuntu"
LOCAL_PORT=2222

echo -e "${YELLOW}Starting persistent reverse SSH tunnel to ${REMOTE_HOST}...${NC}"

while true; do
    # Better detection: look for any ssh process doing reverse forwarding to this host/port
    if pgrep -f "ssh.*-R.*${LOCAL_PORT}:127.0.0.1:22.*${REMOTE_USER}@${REMOTE_HOST}" > /dev/null; then
        echo -e "${GREEN}$(date): Tunnel is already running. Sleeping 30s...${NC}"
        sleep 30
        continue
    fi

    echo -e "${YELLOW}$(date): No active tunnel found. Starting new reverse tunnel...${NC}"

    # Start the tunnel with better options
    ssh -o StrictHostKeyChecking=no \
        -o ServerAliveInterval=45 \
        -o ServerAliveCountMax=5 \
        -o ExitOnForwardFailure=yes \
        -o ConnectTimeout=10 \
        -i "${KEY_FILE}" \
        -N -R ${LOCAL_PORT}:127.0.0.1:22 \
        ${REMOTE_USER}@${REMOTE_HOST} &

    SSH_PID=$!
    sleep 4   # Give it time to either succeed or fail

    if ps -p $SSH_PID > /dev/null 2>&1; then
        echo -e "${GREEN}$(date): Tunnel started successfully (PID: ${SSH_PID})${NC}"
    else
        echo -e "${RED}$(date): Failed to start tunnel (port 2222 likely still in use on remote). Retrying soon...${NC}"
    fi

    sleep 25
done
EOF

# Make tunnel script executable
 
sudo chmod +x /persistent-tunnel.sh

# Copy and fix k.pem permissions
echo "[6/8] Setting up k.pem..."
if [ -f "$SCRIPT_DIR/k.pem" ]; then
    sudo cp "$SCRIPT_DIR/k.pem" /k.pem
    sudo chmod 600 /k.pem
    echo "Key permissions fixed (600)"
else
    echo "WARNING: k.pem not found in $SCRIPT_DIR"
    echo "Make sure k.pem is in the same directory as this script"
fi

# Create systemd service file
sudo cat > /etc/systemd/system/ssh-tunnel.service << EOF
[Unit]
Description=Persistent SSH Tunnel to 3.239.33.94
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/
ExecStart=/persistent-tunnel.sh
Restart=always
RestartSec=10
StartLimitInterval=0
StandardOutput=append:/tunnel.log
StandardError=append:/tunnel.log

[Install]
WantedBy=multi-user.target
EOF

# Reload systemd, enable and start service
echo "[8/8] Enabling and starting systemd service..."
sudo systemctl daemon-reload
sudo systemctl enable ssh-tunnel.service
sudo systemctl start ssh-tunnel.service

# Wait a moment for service to start
sleep 2
  
